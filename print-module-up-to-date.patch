+++ b/src/app/api/print/editions/[id]/sync-budget/route.js
@@ -0,0 +1,219 @@
+// POST /api/print/editions/[id]/sync-budget
+//
+// The budget→edition bridge. Reads the editorial page assignments for
+// this edition's publication + date and seeds them into the edition's
+// per-folio `assets` so Build Pages places them automatically.
+//
+// Page source per kind:
+//   story      → story.pageAssignment (set in the print-budget sheet),
+//                with printCuts[siteId].pageAssignment overriding.
+//   classified → classifieds/{classifiedId}.autopagePage  (set in /admin/autopage)
+//   obituary   → obituaries/{obituaryId}.autopagePage
+//   legal      → legals/{id}.autopagePage
+//
+// Folio strings are normalized ("A-1" → "A1") and matched against the
+// edition's actual folios. Merge is ADDITIVE + deduped by kind:id, so
+// re-running is safe and never clobbers manually-added assets. Assets
+// whose page doesn't map to a folio are returned in `unmatched` (never
+// silently dropped). Folios actively checked out by another user are
+// skipped (returned in `skippedLocked`).
+
+import { NextResponse } from 'next/server';
+import { authorize } from '@/lib/api-auth';
+import { EDITIONS_COLLECTION, ASSET_KIND_SET, validatePageAssets } from '@/lib/print-editions';
+import { getPageFile, lockHeldBy, isLockExpired } from '@/lib/print-page-files';
+import { isDemoMode, getEditionMemory, putEditionMemory, demoAssetsFor } from '@/lib/print-demo';
+
+export const runtime = 'nodejs';
+export const dynamic = 'force-dynamic';
+
+// "A-1" / "a1" / "B-03" → "A1" / "B3". Edition folios are single-letter +
+// number (foliosFromSections emits `${letter}${i}`). Free-text pages like
+// "Opinion" or "Sports-1" don't reduce to that form and return as-is in
+// uppercase — they simply won't match a folio and land in `unmatched`.
+function normalizeFolio(s) {
+  if (!s) return null;
+  const t = String(s).trim().toUpperCase();
+  const m = t.match(/^([A-Z]+)-?0*(\d+)$/);
+  return m ? `${m[1]}${m[2]}` : t;
+}
+
+async function loadEdition(db, id) {
+  if (isDemoMode()) return getEditionMemory(id);
+  const snap = await db.collection(EDITIONS_COLLECTION).doc(id).get();
+  return snap.exists ? { id: snap.id, ...snap.data() } : null;
+}
+
+// Returns [{ kind, id, page }] — the editorial page assignment for every
+// budget item slated for this edition's publication + date.
+async function loadBudgetAssignments(db, { siteId, date }) {
+  if (isDemoMode()) {
+    return (demoAssetsFor(siteId, date) || []).map(a => ({
+      kind: a.assetType || 'story',
+      id: a.id,
+      page: a.pageAssignment || '',
+    }));
+  }
+
+  const out = [];
+
+  // Stories — page from the budget sheet (pageAssignment / printCuts).
+  try {
+    const snap = await db.collection('stories')
+      .where('includeInPrintBudget', '==', true)
+      .where('editionDate', '==', date)
+      .limit(500).get();
+    for (const doc of snap.docs) {
+      const d = doc.data() || {};
+      const docSites = d.sites && d.sites.length ? d.sites : ['wvnews'];
+      if (!(docSites.includes(siteId) || d.printSiteId === siteId)) continue;
+      const cut = d.printCuts && d.printCuts[siteId];
+      out.push({ kind: 'story', id: doc.id, page: (cut && cut.pageAssignment) || d.pageAssignment || '' });
+    }
+  } catch (err) { console.warn('[sync-budget] stories load skipped:', err?.message || err); }
+
+  // Classifieds — page from the source classified's autopagePage (/admin/autopage).
+  // Asset id is the queue doc id (what the asset-content endpoint reads).
+  await loadQueueKindAssignments(db, out, {
+    queue: 'print_classifieds_queue', kind: 'classified',
+    match: c => c.paperSlug === siteId,
+    sourceCollection: 'classifieds', sourceIdField: 'classifiedId',
+  });
+
+  // Obituaries — page from obituaries/{obituaryId}.autopagePage.
+  await loadQueueKindAssignments(db, out, {
+    queue: 'print_obits_queue', kind: 'obituary',
+    match: o => Array.isArray(o.targetEditions) && o.targetEditions.includes(siteId),
+    sourceCollection: 'obituaries', sourceIdField: 'obituaryId',
+  });
+
+  // Legals — page from legals.autopagePage; live on this date for this pub.
+  try {
+    const snap = await db.collection('legals')
+      .where('status', '==', 'Published').limit(500).get();
+    for (const doc of snap.docs) {
+      const l = doc.data() || {};
+      const pubs = l.targetPublications || l.publicationIds || [];
+      const started = !l.startDate || l.startDate <= date;
+      const notEnded = !l.endDate || l.endDate >= date;
+      if (pubs.includes(siteId) && started && notEnded) {
+        out.push({ kind: 'legal', id: doc.id, page: l.autopagePage || '' });
+      }
+    }
+  } catch (err) { console.warn('[sync-budget] legals load skipped:', err?.message || err); }
+
+  return out;
+}
+
+// Queue-backed kinds (classifieds, obits): the page lives on the SOURCE
+// doc's autopagePage, not the queue. Join queue→source per pending item.
+async function loadQueueKindAssignments(db, out, { queue, kind, match, sourceCollection, sourceIdField }) {
+  try {
+    const snap = await db.collection(queue)
+      .where('status', 'in', ['queued', 'in-layout']).limit(500).get();
+    const rows = snap.docs.map(d => ({ id: d.id, ...d.data() })).filter(match);
+    await Promise.all(rows.map(async (r) => {
+      let page = r.pageAssignment || '';
+      const srcId = r[sourceIdField];
+      if (srcId) {
+        try {
+          const s = await db.collection(sourceCollection).doc(String(srcId)).get();
+          if (s.exists) page = s.data().autopagePage || page;
+        } catch { /* source lookup best-effort */ }
+      }
+      out.push({ kind, id: r.id, page });
+    }));
+  } catch (err) { console.warn(`[sync-budget] ${queue} load skipped:`, err?.message || err); }
+}
+
+export async function POST(request, { params }) {
+  const authz = await authorize(request, 'printlayout');
+  if (!authz) return NextResponse.json({ error: 'Unauthorized' }, { status: 401 });
+
+  const { id } = params;
+  if (!id) return NextResponse.json({ error: 'edition id required' }, { status: 400 });
+
+  const { db } = isDemoMode() ? {} : await import('@/lib/firebase-admin');
+
+  const edition = await loadEdition(db, id);
+  if (!edition) return NextResponse.json({ error: 'Edition not found' }, { status: 404 });
+  if (!edition.siteId || !edition.editionDate) {
+    return NextResponse.json({ error: 'Edition is missing siteId/editionDate' }, { status: 400 });
+  }
+
+  const pages = Array.isArray(edition.pages) ? edition.pages.map(p => ({ ...p })) : [];
+  const folioSet = new Set(pages.map(p => p.folio));
+
+  const assignments = await loadBudgetAssignments(db, { siteId: edition.siteId, date: edition.editionDate });
+
+  // Bucket assignments by target folio; collect anything that doesn't map.
+  const byFolio = {};
+  const unmatched = [];
+  for (const a of assignments) {
+    if (!ASSET_KIND_SET.has(a.kind)) continue;
+    const folio = normalizeFolio(a.page);
+    if (folio && folioSet.has(folio)) {
+      (byFolio[folio] = byFolio[folio] || []).push({ kind: a.kind, id: a.id });
+    } else {
+      unmatched.push({ kind: a.kind, id: a.id, page: a.page || '' });
+    }
+  }
+
+  // Additive merge into each page's assets, deduped by kind:id. Skip folios
+  // that are checked out by another user (don't change assignments under an
+  // active InDesign session).
+  const assigned = {};
+  const skippedLocked = [];
+  for (let i = 0; i < pages.length; i++) {
+    const p = pages[i];
+    const add = byFolio[p.folio];
+    if (!add || !add.length) continue;
+
+    try {
+      const pageFile = await getPageFile({ editionId: id, folio: p.folio });
+      if (pageFile?.lock && !isLockExpired(pageFile.lock) && !lockHeldBy(pageFile.lock, authz.user)) {
+        skippedLocked.push(p.folio);
+        continue;
+      }
+    } catch { /* lock check best-effort */ }
+
+    const current = Array.isArray(p.assets) ? p.assets.slice() : [];
+    const keys = new Set(current.map(x => `${x.kind}:${x.id}`));
+    let count = 0;
+    for (const a of add) {
+      const key = `${a.kind}:${a.id}`;
+      if (keys.has(key)) continue;
+      current.push(a);
+      keys.add(key);
+      count++;
+    }
+    if (count) {
+      assigned[p.folio] = count;
+      pages[i] = { ...p, assets: current };
+    }
+  }
+
+  // Validate the resulting asset arrays before persisting.
+  for (const p of pages) {
+    const errs = validatePageAssets(Array.isArray(p.assets) ? p.assets : []);
+    if (errs.length) {
+      return NextResponse.json({ error: `${p.folio}: ${errs.join('; ')}` }, { status: 400 });
+    }
+  }
+
+  const updatedAt = new Date().toISOString();
+  if (isDemoMode()) {
+    putEditionMemory({ ...edition, pages, updatedAt });
+  } else {
+    await db.collection(EDITIONS_COLLECTION).doc(id).update({ pages, updatedAt });
+  }
+
+  const totalAssigned = Object.values(assigned).reduce((n, c) => n + c, 0);
+  return NextResponse.json({
+    ok: true,
+    assigned,            // { folio: count } of newly-added assets
+    totalAssigned,
+    unmatched,           // [{kind, id, page}] — page didn't map to a folio
+    skippedLocked,       // folios skipped because checked out by someone else
+  });
+}
