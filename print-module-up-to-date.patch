+// GET /api/print/marketplace/[siteId]/[kind]?date=YYYY-MM-DD
+//
+// Lists the available classifieds / legals / obits for a publication so
+// the plugin's Marketplace tab can pull them and place a block. Unlike
+// the per-asset endpoint (which is edition-scoped), this is keyed by the
+// publication, returning everything currently slated for print.
+//
+//   kind = 'classifieds' → print_classifieds_queue (status queued, paperSlug==site)
+//   kind = 'obits'       → print_obits_queue (status queued, targetEditions has site)
+//   kind = 'legals'      → legals (Published, targetPublications has site, live on date)
+
+import { NextResponse } from 'next/server';
+import { authorize } from '@/lib/api-auth';
+import { isDemoMode, listDemoClassifiedsForEdition } from '@/lib/print-demo';
+
+export const runtime = 'nodejs';
+export const dynamic = 'force-dynamic';
+
+const KINDS = new Set(['classifieds', 'legals', 'obits']);
+
+export async function GET(request, { params }) {
+  const authz = await authorize(request, 'printlayout');
+  if (!authz) return NextResponse.json({ error: 'Unauthorized' }, { status: 401 });
+
+  const { siteId, kind } = params;
+  if (!siteId) return NextResponse.json({ error: 'siteId required' }, { status: 400 });
+  if (!KINDS.has(kind)) return NextResponse.json({ error: `unknown kind: ${kind}` }, { status: 400 });
+  const date = new URL(request.url).searchParams.get('date') || '';
+
+  let items = [];
+  try {
+    if (isDemoMode()) {
+      if (kind === 'classifieds') {
+        items = (listDemoClassifiedsForEdition(siteId, date) || []).map(c => ({
+          id: c.id, category: c.category || '', text: c.text || '', phone: c.phone || '', city: c.city || '',
+        }));
+      }
+      // obits/legals have no demo fixtures yet → empty in demo.
+    } else {
+      const { db } = await import('@/lib/firebase-admin');
+      if (kind === 'classifieds') {
+        const snap = await db.collection('print_classifieds_queue')
+          .where('status', 'in', ['queued', 'in-layout']).limit(500).get();
+        items = snap.docs.map(d => ({ id: d.id, ...d.data() }))
+          .filter(c => c.paperSlug === siteId)
+          .map(c => ({
+            id: c.id,
+            category: c.category || '',
+            text: c.line || c.headline || '',
+            phone: c.phone || '',
+            city: c.city || '',
+          }));
+      } else if (kind === 'obits') {
+        const snap = await db.collection('print_obits_queue')
+          .where('status', 'in', ['queued', 'in-layout']).limit(500).get();
+        items = snap.docs.map(d => ({ id: d.id, ...d.data() }))
+          .filter(o => Array.isArray(o.targetEditions) && o.targetEditions.includes(siteId))
+          .map(o => ({
+            id: o.id, name: o.name || '', city: o.city || '',
+            dob: o.dob || '', dod: o.dod || '', text: o.text || '', funeral: o.funeral || '',
+          }));
+      } else { // legals
+        const snap = await db.collection('legals')
+          .where('status', '==', 'Published').limit(500).get();
+        items = snap.docs.map(d => ({ id: d.id, ...d.data() }))
+          .filter(l => {
+            const pubs = l.targetPublications || l.publicationIds || [];
+            const started = !l.startDate || !date || l.startDate <= date;
+            const notEnded = !l.endDate || !date || l.endDate >= date;
+            return pubs.includes(siteId) && started && notEnded;
+          })
+          .map(l => ({
+            id: l.id,
+            title: l.title || l.fields?.title || '',
+            noticeType: l.type || l.noticeType || '',
+            text: l.text || l.fields?.text || '',
+          }));
+      }
+    }
+  } catch (err) {
+    console.error(`[print/marketplace] ${kind} load failed for ${siteId}:`, err?.message || err);
+    return NextResponse.json({ error: 'load failed' }, { status: 500 });
+  }
+
+  return NextResponse.json({ kind, siteId, count: items.length, items });
+}
