{
  "id": "com.wvnews.print",
  "name": "WVNews Print",
  "version": "0.1.7",
  "main": "index.html",
  "manifestVersion": 5,
  "host": {
    "app": "ID",
    "minVersion": "18.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "wvnews-print-panel",
      "label": {
        "default": "WVNews Print"
      },
      "minimumSize": { "width": 320, "height": 400 },
      "maximumSize": { "width": 2000, "height": 2000 },
      "preferredDockedSize": { "width": 360, "height": 600 },
      "preferredFloatingSize": { "width": 360, "height": 600 },
      "icons": [
        {
          "width": 23,
          "height": 23,
          "path": "icons/icon-dark.png",
          "scale": [1, 2],
          "theme": ["darkest", "dark", "medium"]
        },
        {
          "width": 23,
          "height": 23,
          "path": "icons/icon-light.png",
          "scale": [1, 2],
          "theme": ["lightest", "light"]
        }
      ]
    }
  ],
  "icons": [
    {
      "width": 48,
      "height": 48,
      "path": "icons/icon-light.png",
      "scale": [1, 2],
      "theme": ["darkest", "dark", "medium", "lightest", "light", "all"],
      "species": ["pluginList"]
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "fullAccess",
    "network": {
      "domains": [
        "http://localhost:3000",
        "https://staging.wvnews.com",
        "https://wvnews.com",
        "https://firebasestorage.googleapis.com",
        "https://storage.googleapis.com"
      ]
    },
    "launchProcess": {
      "schemes": ["https"]
    }
  }
}
