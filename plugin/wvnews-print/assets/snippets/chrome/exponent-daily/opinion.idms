stified" Justification="CenterAlign">			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]" FontStyle="Light" HorizontalScale="93">				<Properties>					<AppliedFont type="string">Franklin Gothic ATF</AppliedFont>				</Properties>				<Br/>			</CharacterStyleRange>		</ParagraphStyleRange>		<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/OpinionLettersBullets">			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]" HorizontalScale="93">				<Content>E-mail letter to: news@wvnews.com or cyoung@wvnews.com</Content>				<Br/>				<Content>Fax your letter to: 304-624-4188.</Content>				<Br/>				<Content>Be sure to include your name, address and daytime telephone number. Letters must be signed.</Content>				<Br/>				<Content>Letters are limited to about 400 words.</Content>				<Br/>				<Content>Letters should address issues of importance on the local, state and national level.</Content>				<Br/>				<Content>Multiple letters from the same person within a one month period or form letters will not be considered.</Content>				<Br/>				<Content>Letters regarding the upcoming General Election must be received by Oct. 16 for consideration.</Content>				<Br/>				<Content>No letters regarding the election will be published after Oct. 21.</Content>			</CharacterStyleRange>		</ParagraphStyleRange>	</Story>	<Story Self="u4a1" UserText="true" IsEndnoteStory="false" AppliedTOCStyle="n" TrackChanges="false" StoryTitle="$ID/" AppliedNamedGrid="n">		<StoryPreference OpticalMarginAlignment="false" OpticalMarginSize="12" FrameType="TextFrameType" StoryOrientation="Horizontal" StoryDirection="LeftToRightDirection"/>		<InCopyExportOption IncludeGraphicProxies="true" IncludeAllResources="false"/>		<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/BCJ Body Copy Justified">			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]"/>		</ParagraphStyleRange>