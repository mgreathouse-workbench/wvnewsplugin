ge AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">				<Content>See the classified section for information about placing an ad, or you can call us between 7 a.m. and 5 p.m. Monday through Friday.</Content>				<Br/>				<Br/>				<Content>Fax: 304-622-3629</Content>				<Br/>				<Content>Classified@wvnews.com</Content>			</CharacterStyleRange>		</ParagraphStyleRange>	</Story>	<Story Self="u452" UserText="true" IsEndnoteStory="false" AppliedTOCStyle="n" TrackChanges="false" StoryTitle="$ID/" AppliedNamedGrid="n">		<StoryPreference OpticalMarginAlignment="false" OpticalMarginSize="12" FrameType="TextFrameType" StoryOrientation="Horizontal" StoryDirection="LeftToRightDirection"/>		<InCopyExportOption IncludeGraphicProxies="true" IncludeAllResources="false"/>		<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/ContactBody">			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">				<Content>To start a home delivery subscription or to let us know about a service problem, call from 9 a.m. to 4 p.m. Monday through Friday.</Content>				<Br/>				<Br/>				<Content>Circulation@wvnews.com</Content>			</CharacterStyleRange>		</ParagraphStyleRange>	</Story>	<Story Self="u43c" UserText="true" IsEndnoteStory="false" AppliedTOCStyle="n" TrackChanges="false" StoryTitle="$ID/" AppliedNamedGrid="n">		<StoryPreference OpticalMarginAlignment="false" OpticalMarginSize="12" FrameType="TextFrameType" StoryOrientation="Horizontal" StoryDirection="LeftToRightDirection"/>		<InCopyExportOption IncludeGraphicProxies="true" IncludeAllResources="false"/>		<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/NewsPhone">			<Properties>				<TabList type="list">					<ListItem type="record">						<Alignment type="enumeration">RightAlign</Alignment>						<AlignmentCharacter type="string">.</AlignmentCharacter>						<Leader type="string">.</Leader>						<Position type="unit">118</Position>					</ListItem>				</Tab